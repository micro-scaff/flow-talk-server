{
  "openapi": "3.0.3",
  "info": {
    "title": "flow-talk-server 人员信息接口",
    "description": "当前服务已实现的注册、登录、当前用户和用户列表接口。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "认证",
      "description": "注册、登录、当前用户"
    },
    {
      "name": "用户",
      "description": "用户信息接口"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["认证"],
        "summary": "注册",
        "description": "创建本地用户，注册成功后直接返回用户信息和登录 token。",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "username": "alice",
                "password": "123456",
                "nickname": "Alice",
                "avatar_url": "https://example.com/avatar.png"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "参数校验失败"
                }
              }
            }
          },
          "409": {
            "description": "用户名已存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "用户名已存在"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["认证"],
        "summary": "登录",
        "description": "使用本地账号密码登录，成功后返回用户信息和新的 token。",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "alice",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "参数校验失败"
                }
              }
            }
          },
          "401": {
            "description": "账号或密码错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "账号或密码错误"
                }
              }
            }
          },
          "403": {
            "description": "用户已禁用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "用户已禁用"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["认证"],
        "summary": "获取当前用户",
        "description": "根据请求头中的 token 返回当前登录用户信息。",
        "operationId": "getCurrentUser",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["用户"],
        "summary": "获取用户列表",
        "description": "返回数据库中的所有用户信息。当前接口用于管理和调试。",
        "operationId": "listUsers",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "登录或注册接口返回的 token。"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "未登录或登录已失效",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "未登录或登录已失效"
            }
          }
        }
      },
      "InternalError": {
        "description": "服务器内部错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "服务器内部错误"
            }
          }
        }
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "登录账号，必须唯一",
            "example": "alice"
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "123456"
          },
          "nickname": {
            "type": "string",
            "description": "展示昵称，不传时默认使用 username",
            "example": "Alice"
          },
          "avatar_url": {
            "type": "string",
            "description": "头像地址",
            "example": "https://example.com/avatar.png"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "登录账号",
            "example": "alice"
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "123456"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "用户内部 ID",
            "example": 1
          },
          "external_id": {
            "type": "string",
            "description": "外部系统用户 ID，本地注册用户通常为空",
            "example": ""
          },
          "username": {
            "type": "string",
            "description": "登录账号",
            "example": "alice"
          },
          "nickname": {
            "type": "string",
            "description": "展示昵称",
            "example": "Alice"
          },
          "avatar_url": {
            "type": "string",
            "description": "头像地址",
            "example": "https://example.com/avatar.png"
          },
          "auth_source": {
            "type": "string",
            "description": "用户来源",
            "example": "local"
          },
          "status": {
            "type": "integer",
            "description": "用户状态，1 正常，0 禁用",
            "example": 1
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "错误信息",
            "example": "参数校验失败"
          }
        }
      }
    }
  }
}
