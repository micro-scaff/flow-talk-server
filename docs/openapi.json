{
  "openapi": "3.0.3",
  "info": {
    "title": "flow-talk-server 接口",
    "description": "当前服务已实现的用户、认证和会话基础接口。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "认证",
      "description": "注册、登录、当前用户"
    },
    {
      "name": "用户",
      "description": "用户信息接口"
    },
    {
      "name": "会话",
      "description": "单聊、群聊和会话成员接口"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["认证"],
        "summary": "注册",
        "description": "创建本地用户，注册成功后直接返回用户信息和登录 token。",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "username": "alice",
                "password": "123456",
                "nickname": "Alice",
                "avatar_url": "https://example.com/avatar.png"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthApiResponse"
                },
                "example": {
                  "code": 200,
                  "data": {
                    "token": "<jwt-token>",
                    "user": {
                      "id": 1,
                      "username": "alice",
                      "nickname": "Alice",
                      "avatar_url": "https://example.com/avatar.png",
                      "auth_source": "local",
                      "status": 1
                    }
                  },
                  "message": "注册成功"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "409": {
            "$ref": "#/components/responses/UsernameTaken"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["认证"],
        "summary": "登录",
        "description": "使用本地账号密码登录，成功后返回用户信息和新的 token。",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "alice",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthApiResponse"
                },
                "example": {
                  "code": 200,
                  "data": {
                    "token": "<jwt-token>",
                    "user": {
                      "id": 1,
                      "username": "alice",
                      "nickname": "Alice",
                      "avatar_url": "https://example.com/avatar.png",
                      "auth_source": "local",
                      "status": 1
                    }
                  },
                  "message": "登录成功"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/InvalidCredentials"
          },
          "403": {
            "$ref": "#/components/responses/UserDisabled"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["认证"],
        "summary": "获取当前用户",
        "description": "根据请求头中的 token 返回当前登录用户信息。",
        "operationId": "getCurrentUser",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserApiResponse"
                },
                "example": {
                  "code": 200,
                  "data": {
                    "id": 1,
                    "username": "alice",
                    "nickname": "Alice",
                    "avatar_url": "https://example.com/avatar.png",
                    "auth_source": "local",
                    "status": 1
                  },
                  "message": "获取当前用户成功"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/conversations": {
      "get": {
        "tags": ["会话"],
        "summary": "获取会话列表",
        "description": "返回当前用户参与且状态为 active 的会话列表。",
        "operationId": "listConversations",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationListApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/conversations/{conversation_id}": {
      "get": {
        "tags": ["会话"],
        "summary": "获取会话详情",
        "description": "返回单个会话详情和成员列表，只允许会话 active 成员访问。",
        "operationId": "getConversationDetail",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetailApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/conversations/direct": {
      "post": {
        "tags": ["会话"],
        "summary": "创建或获取单聊",
        "description": "根据目标用户创建或获取单聊会话，服务端使用 direct_key 防止重复创建。",
        "operationId": "createDirectConversation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDirectConversationRequest"
              },
              "example": {
                "target_user_id": 2
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetailApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/conversations/groups": {
      "post": {
        "tags": ["会话"],
        "summary": "创建群聊",
        "description": "创建群聊并写入群成员，当前用户自动成为群主。",
        "operationId": "createGroupConversation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGroupConversationRequest"
              },
              "example": {
                "title": "测试群",
                "avatar_url": "",
                "member_ids": [2, 3]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationApiResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["用户"],
        "summary": "获取用户列表",
        "description": "返回数据库中的所有用户信息。当前接口用于管理和调试。",
        "operationId": "listUsers",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListApiResponse"
                },
                "example": {
                  "code": 200,
                  "data": [
                    {
                      "id": 2,
                      "username": "bob",
                      "nickname": "Bob",
                      "avatar_url": "",
                      "auth_source": "local",
                      "status": 1
                    },
                    {
                      "id": 1,
                      "username": "alice",
                      "nickname": "Alice",
                      "avatar_url": "https://example.com/avatar.png",
                      "auth_source": "local",
                      "status": 1
                    }
                  ],
                  "message": "获取用户列表成功"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "登录或注册接口返回的 token。"
      }
    },
    "responses": {
      "ValidationError": {
        "description": "参数校验失败",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 400,
              "data": null,
              "message": "参数校验失败"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "未登录或登录已失效",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 401,
              "data": null,
              "message": "未登录或登录已失效"
            }
          }
        }
      },
      "InvalidCredentials": {
        "description": "账号或密码错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 401,
              "data": null,
              "message": "账号或密码错误"
            }
          }
        }
      },
      "UserDisabled": {
        "description": "用户已禁用",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 403,
              "data": null,
              "message": "用户已禁用"
            }
          }
        }
      },
      "UsernameTaken": {
        "description": "用户名已存在",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 409,
              "data": null,
              "message": "用户名已存在"
            }
          }
        }
      },
      "Forbidden": {
        "description": "无权访问目标资源",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 403,
              "data": null,
              "message": "无权访问该会话"
            }
          }
        }
      },
      "NotFound": {
        "description": "目标资源不存在",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 404,
              "data": null,
              "message": "会话不存在"
            }
          }
        }
      },
      "InternalError": {
        "description": "服务器内部错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorApiResponse"
            },
            "example": {
              "code": 500,
              "data": null,
              "message": "服务器内部错误"
            }
          }
        }
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "登录账号，必须唯一",
            "example": "alice"
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "123456"
          },
          "nickname": {
            "type": "string",
            "description": "展示昵称，不传时默认使用 username",
            "example": "Alice"
          },
          "avatar_url": {
            "type": "string",
            "description": "头像地址",
            "example": "https://example.com/avatar.png"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "登录账号",
            "example": "alice"
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "123456"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "用户内部 ID",
            "example": 1
          },
          "external_id": {
            "type": "string",
            "description": "外部系统用户 ID，本地注册用户通常为空",
            "example": ""
          },
          "username": {
            "type": "string",
            "description": "登录账号",
            "example": "alice"
          },
          "nickname": {
            "type": "string",
            "description": "展示昵称",
            "example": "Alice"
          },
          "avatar_url": {
            "type": "string",
            "description": "头像地址",
            "example": "https://example.com/avatar.png"
          },
          "auth_source": {
            "type": "string",
            "description": "用户来源",
            "example": "local"
          },
          "status": {
            "type": "integer",
            "description": "用户状态，1 正常，0 禁用",
            "example": 1
          }
        }
      },
      "AuthData": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "AuthApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/AuthData"
          },
          "message": {
            "type": "string",
            "example": "登录成功"
          }
        }
      },
      "UserApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/User"
          },
          "message": {
            "type": "string",
            "example": "获取当前用户成功"
          }
        }
      },
      "UserListApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "message": {
            "type": "string",
            "example": "获取用户列表成功"
          }
        }
      },
      "CreateDirectConversationRequest": {
        "type": "object",
        "required": ["target_user_id"],
        "properties": {
          "target_user_id": {
            "type": "integer",
            "format": "int64",
            "description": "目标用户 ID",
            "example": 2
          }
        }
      },
      "CreateGroupConversationRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "description": "群聊名称",
            "example": "测试群"
          },
          "avatar_url": {
            "type": "string",
            "description": "群聊头像",
            "example": ""
          },
          "member_ids": {
            "type": "array",
            "description": "群成员用户 ID，当前用户会由服务端自动补齐",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "example": [2, 3]
          }
        }
      },
      "ConversationMember": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "role": {
            "type": "string",
            "example": "owner"
          },
          "status": {
            "type": "string",
            "example": "active"
          }
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "type": {
            "type": "string",
            "example": "group"
          },
          "direct_key": {
            "type": "string",
            "example": "1:2"
          },
          "title": {
            "type": "string",
            "example": "测试群"
          },
          "avatar_url": {
            "type": "string",
            "example": ""
          },
          "owner_id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "member_count": {
            "type": "integer",
            "format": "int64",
            "example": 3
          },
          "last_message_id": {
            "type": "integer",
            "format": "int64",
            "example": 0
          },
          "last_message_at": {
            "type": "string",
            "example": ""
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationMember"
            }
          }
        }
      },
      "ConversationListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "type": {
            "type": "string",
            "example": "direct"
          },
          "title": {
            "type": "string",
            "example": ""
          },
          "avatar_url": {
            "type": "string",
            "example": ""
          },
          "owner_id": {
            "type": "integer",
            "format": "int64",
            "example": 0
          },
          "member_count": {
            "type": "integer",
            "format": "int64",
            "example": 2
          },
          "last_message_id": {
            "type": "integer",
            "format": "int64",
            "example": 0
          },
          "last_message_at": {
            "type": "string",
            "example": ""
          }
        }
      },
      "ConversationApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/Conversation"
          },
          "message": {
            "type": "string",
            "example": "创建群聊成功"
          }
        }
      },
      "ConversationDetailApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/Conversation"
          },
          "message": {
            "type": "string",
            "example": "获取会话详情成功"
          }
        }
      },
      "ConversationListApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationListItem"
            }
          },
          "message": {
            "type": "string",
            "example": "获取会话列表成功"
          }
        }
      },
      "ErrorApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400
          },
          "data": {
            "nullable": true,
            "example": null
          },
          "message": {
            "type": "string",
            "description": "接口信息或错误信息",
            "example": "参数校验失败"
          }
        }
      }
    }
  }
}
